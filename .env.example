# ============================================================
# IMMO-BOT — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Intervalle entre les scans (en secondes, défaut: 180 = 3 min)
SCAN_INTERVAL=180

# Chemin de la base SQLite
DB_PATH=listings.db

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================
# NOTIFICATIONS — Choisir au moins un canal
# ============================================================

# --- Option 1 : Free Mobile SMS (GRATUIT) ---
# Activer sur : https://mobile.free.fr/account/mes-options
# Identifiant = votre numéro sans le 0 (ex: 612345678)
FREE_MOBILE_USER=
FREE_MOBILE_PASS=

# --- Option 2 : Twilio SMS (~0.04€/SMS) ---
# Créer un compte sur : https://www.twilio.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+33xxxxxxxxx
TWILIO_TO=+33xxxxxxxxx

# --- Option 3 : Telegram (GRATUIT) ---
# 1. Parler à @BotFather sur Telegram → /newbot → copier le token
# 2. Parler à @userinfobot pour avoir votre chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
